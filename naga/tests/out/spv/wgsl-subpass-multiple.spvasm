%13 = OpVariable  %14  Output
%16 = OpTypeFunction %2
%20 = OpConstant  %7  0
%21 = OpConstantComposite  %6  %20 %20
%22 = OpConstant  %4  3
%23 = OpConstantComposite  %5  %22 %22 %22 %22
%15 = OpFunction  %2  None %16
%12 = OpLabel
%17 = OpLoad  %3  %8
%18 = OpLoad  %3  %10
%19 = OpLoad  %3  %11
OpBranch %24
%24 = OpLabel
%25 = OpImageRead  %5  %17 %21
%26 = OpImageRead  %5  %18 %21
%27 = OpImageRead  %5  %19 %21
%28 = OpFAdd  %5  %25 %26
%29 = OpFAdd  %5  %28 %27
%30 = OpFDiv  %5  %29 %23
