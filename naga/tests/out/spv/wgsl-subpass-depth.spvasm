; SPIR-V
; Version: 1.1
; Generator: rspirv
; Bound: 24
OpCapability Shader
%1 = OpExtInstImport "GLSL.std.450"
OpMemoryModel Logical GLSL450
OpEntryPoint Fragment %13 "main" %11
OpExecutionMode %13 OriginUpperLeft
OpDecorate %8 DescriptorSet 0
OpDecorate %8 Binding 0
OpDecorate %8 InputAttachmentIndex 1
OpDecorate %11 Location 0
%2 = OpTypeVoid
%4 = OpTypeFloat 32
%3 = OpTypeImage %4 SubpassData 1 0 0 1 Unknown
%5 = OpTypeVector %4 4
%7 = OpTypeInt 32 1
%6 = OpTypeVector %7 2
%9 = OpTypePointer UniformConstant %3
%8 = OpVariable  %9  UniformConstant
%12 = OpTypePointer Output %5
%11 = OpVariable  %12  Output
%14 = OpTypeFunction %2
%16 = OpConstant  %7  4
%17 = OpConstant  %7  8
%18 = OpConstantComposite  %6  %16 %17
%19 = OpConstant  %4  1
%13 = OpFunction  %2  None %14
%10 = OpLabel
%15 = OpLoad  %3  %8
OpBranch %20
%20 = OpLabel
%21 = OpImageRead  %5  %15 %18
%22 = OpCompositeExtract  %4  %21 0
%23 = OpCompositeConstruct  %5  %22 %22 %22 %19
OpStore %11 %23
OpReturn
OpFunctionEnd