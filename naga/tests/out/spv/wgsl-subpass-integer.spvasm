%10 = OpTypePointer Output %5
%9 = OpVariable  %10  Output
%12 = OpTypeFunction %2
%16 = OpTypeInt 32 1
%15 = OpConstant  %16  0
%18 = OpTypeVector %16 2
%17 = OpConstantComposite  %18  %15 %15
%11 = OpFunction  %2  None %12
%8 = OpLabel
%13 = OpLoad  %3  %6
OpBranch %14
%14 = OpLabel
%19 = OpImageRead  %5  %13 %17
